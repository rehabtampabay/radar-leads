// ── STATE (persisted in localStorage) ──
const STORE_KEY = "radar_pasco_v2";
function loadState() {
  try { return JSON.parse(localStorage.getItem(STORE_KEY)) || {}; } catch { return {}; }
}
function saveState(state) {
  localStorage.setItem(STORE_KEY, JSON.stringify(state));
  document.getElementById('save-badge').textContent = '✓ Saved';
  setTimeout(()=>document.getElementById('save-badge').textContent='', 2000);
}

let STATE = loadState();

function getLeadState(id) {
  return STATE[id] || { prFirst:'', prLast:'', prPhone:'', prEmail:'', prAddr:'', prNotes:'', ghl:'Not Sent', pdf:'' };
}
function setLeadState(id, field, val) {
  if (!STATE[id]) STATE[id] = getLeadState(id);
  STATE[id][field] = val;
  saveState(STATE);
}

// ── HELPERS ──
function daysUntil(ds) {
  if (!ds) return null;
  const d = new Date(ds+'T00:00:00');
  return Math.round((d - TODAY) / 86400000);
}
function fmtDeadline(ds) {
  if (!ds) return '';
  const days = daysUntil(ds);
  const [y,m,d] = ds.split('-');
  const mo = ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][+m];
  const base = `${mo} ${+d}`;
  if (days === null) return base;
  if (days < 0) return `${base} (passed)`;
  if (days === 0) return `${base} — TODAY`;
  if (days === 1) return `${base} — TOMORROW`;
  return `${base} — ${days} days`;
}
function tier(score, ds) {
  const days = daysUntil(ds);
  if (days !== null && days < 0) return 'passed';
  if (days !== null && days <= 3 && score > 0) return 'urgent';
  if (score >= 85 || (days !== null && days <= 10)) return 'hot';
  if (score >= 60) return 'warm';
  return 'watch';
}
function dlClass(ds) {
  const d = daysUntil(ds);
  if (d === null) return '';
  if (d < 0) return 'passed';
  if (d <= 3) return 'crit';
  if (d <= 10) return 'soon';
  return 'future';
}
function scoreCls(s) {
  if (!s) return 'sw';
  if (s >= 90) return 's90';
  if (s >= 80) return 's80';
  if (s >= 70) return 's70';
  return 's60';
}
function tpsUrl(name) {
  const clean = name.replace(/^Estate of /i,'').replace(/ — .*/,'').replace(/ \/.*/,'').replace(/\s*\(.*\)/,'').trim();
  return 'https://www.truepeoplesearch.com/results?name=' + encodeURIComponent(clean);
}
function paUrl(name) {
  const clean = name.replace(/^Estate of /i,'').replace(/ — .*/,'').replace(/ \/.*/,'').replace(/\s*\(.*\)/,'').trim();
  const parts = clean.split(' ');
  const last = parts[parts.length-1] || '';
  const first = parts[0] || '';
  return `https://www.pascopa.com/Search/Owner?lastName=${encodeURIComponent(last)}&firstName=${encodeURIComponent(first)}`;
}

function ghlColorClass(val) {
  const map = {'Not Sent':'ns','Sent to GHL':'sent','In Pipeline':'pip','Contacted':'cont','Closed':'closed','Dead Lead':'dead'};
  return map[val] || 'ns';
}

// ── RENDER ──
function render() {
  const search = document.getElementById('search').value.toLowerCase();
  const ft = document.getElementById('filter-type').value;
  const fe = document.getElementById('filter-edition').value;
  const fg = document.getElementById('filter-ghl').value;
  const sort = document.getElementById('sort').value;
  const hidePast = document.getElementById('hide-past').checked;

  let leads = LEADS.filter(l => {
    if (ft && l.type !== ft) return false;
    if (fe && l.edition !== fe) return false;
    if (hidePast && l.deadline && daysUntil(l.deadline) < 0) return false;
    const ls = getLeadState(l.id);
    if (fg && ls.ghl !== fg) return false;
    if (search) {
      const hay = [l.name, l.addr, l.type, l.atty, l.lender, l.edition].join(' ').toLowerCase();
      if (!hay.includes(search)) return false;
    }
    return true;
  });

  if (sort === 'score') {
    leads.sort((a,b) => b.score - a.score);
  } else {
    leads.sort((a,b) => {
      const da = a.deadline ? new Date(a.deadline) : new Date('2099-01-01');
      const db = b.deadline ? new Date(b.deadline) : new Date('2099-01-01');
      return da-db || b.score-a.score;
    });
  }

  // Alert bar
  const urgent = LEADS.filter(l => { const d = daysUntil(l.deadline); return d !== null && d >= 0 && d <= 3 && l.score > 0; });
  const ab = document.getElementById('alert-bar');
  if (urgent.length) {
    ab.style.display = 'flex';
    ab.innerHTML = '⚠️  ' + urgent.map(l=>`<b>${l.name}</b> — ${fmtDeadline(l.deadline)}`).join('&nbsp;&nbsp;·&nbsp;&nbsp;');
  } else {
    ab.style.display = 'none';
  }

  document.getElementById('count-badge').textContent = `${leads.length} of ${LEADS.length} leads`;

  const grid = document.getElementById('grid');
  if (!leads.length) {
    grid.innerHTML = '<div class="empty-state">No leads match your filters.</div>';
    return;
  }

  grid.innerHTML = leads.map(l => {
    const t = tier(l.score, l.deadline);
    const ls = getLeadState(l.id);
    const prHasData = ls.prFirst || ls.prLast || ls.prPhone || ls.prEmail;
    const isProbate = l.type === 'PROBATE';
    const ghlCls = ghlColorClass(ls.ghl);

    return `<div class="card ${t}" id="card-${l.id}">
  <div class="card-head">
    <div class="card-top">
      <div class="card-name">${l.name}</div>
      ${l.score ? `<span class="score-pill ${scoreCls(l.score)}">${l.score}</span>` : ''}
    </div>
    <div class="card-addr">📍 ${l.addr}</div>
    <div class="tags">
      <span class="tag t${l.type.replace(/ /g,'\\ ')}">${l.type}</span>
      <span class="tag t${l.edition.replace(/ /g,'')}">${l.edition}</span>
    </div>
    ${l.deadline ? `<div class="deadline-row">
      <span class="deadline ${dlClass(l.deadline)}">⏰ ${fmtDeadline(l.deadline)}</span>
    </div>` : ''}
    ${l.atty ? `<div class="atty-info">📋 ${l.atty}</div>` : ''}
  </div>

  <div class="quick-links">
    <a class="ql-btn ql-tps" href="${tpsUrl(l.name)}" target="_blank">🔍 TruePeopleSearch</a>
    <a class="ql-btn ql-pa" href="${paUrl(l.name)}" target="_blank">🏠 Pasco PA</a>
    ${ls.pdf
      ? `<a class="ql-btn ql-pdf" href="${ls.pdf}" target="_blank">📄 View PDF</a>`
      : `<span class="ql-btn ql-pdf" onclick="setPdf('${l.id}')" title="Paste PDF link">📄 Add PDF Link</span>`
    }
  </div>

  <div class="pr-section">
    <div class="pr-toggle ${prHasData ? 'open':''}" onclick="togglePR('${l.id}',this)">
      ${isProbate ? '👤 Personal Representative Info' : '👤 Owner / Contact Info'}
      ${prHasData ? ' <span style="color:#1e8449;font-size:.7rem;">✓ filled</span>' : ''}
    </div>
    <div class="pr-fields ${prHasData ? 'visible':''}" id="pr-${l.id}">
      ${isProbate ? `<div class="pr-note pr-full">⚠️ PROBATE: Fill in the Personal Representative — this is who goes to GHL, NOT the deceased.</div>` : ''}
      <div><label>${isProbate ? 'PR First Name' : 'First Name'}</label><input value="${ls.prFirst}" onchange="setLeadState('${l.id}','prFirst',this.value)" placeholder="First"></div>
      <div><label>${isProbate ? 'PR Last Name' : 'Last Name'}</label><input value="${ls.prLast}" onchange="setLeadState('${l.id}','prLast',this.value)" placeholder="Last"></div>
      <div><label>Phone</label><input value="${ls.prPhone}" onchange="setLeadState('${l.id}','prPhone',this.value)" placeholder="(000) 000-0000"></div>
      <div><label>Email</label><input value="${ls.prEmail}" onchange="setLeadState('${l.id}','prEmail',this.value)" placeholder="email@example.com"></div>
      <div class="pr-full"><label>Mailing Address</label><input value="${ls.prAddr}" onchange="setLeadState('${l.id}','prAddr',this.value)" placeholder="Street, City, State ZIP"></div>
      <div class="pr-full"><label>Notes</label><textarea rows="2" onchange="setLeadState('${l.id}','prNotes',this.value)" placeholder="Notes for VA or Bryan...">${ls.prNotes}</textarea></div>
    </div>
  </div>

  <div class="ghl-bar">
    <span class="ghl-label">📤 GHL</span>
    <select class="ghl-select ${ghlCls}" onchange="updateGHL('${l.id}',this)">
      ${['Not Sent','Sent to GHL','In Pipeline','Contacted','Closed','Dead Lead'].map(o=>`<option ${ls.ghl===o?'selected':''}>${o}</option>`).join('')}
    </select>
  </div>
</div>`;
  }).join('');
}

function togglePR(id, btn) {
  btn.classList.toggle('open');
  const el = document.getElementById('pr-'+id);
  el.classList.toggle('visible');
}
function updateGHL(id, sel) {
  const val = sel.value;
  sel.className = 'ghl-select ' + ghlColorClass(val);
  setLeadState(id, 'ghl', val);
}
function setPdf(id) {
  const url = prompt('Paste the PDF link (Google Drive, Dropbox, etc.):');
  if (url && url.startsWith('http')) {
    setLeadState(id, 'pdf', url);
    render();
  }
}

// ── EXPORT / IMPORT ──
function exportData() {
  const blob = new Blob([JSON.stringify(STATE, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'radar_data_' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
  URL.revokeObjectURL(a.href);
}
function importData() {
  const input = document.createElement('input');
  input.type = 'file'; input.accept = '.json';
  input.onchange = e => {
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        STATE = JSON.parse(ev.target.result);
        saveState(STATE);
        render();
        alert('Data imported successfully!');
      } catch { alert('Invalid file.'); }
    };
    reader.readAsText(e.target.files[0]);
  };
  input.click();
}

render();
</script>
