<title>RADAR — Pasco County Lead Board</title>
<style>
:root { color-scheme: light; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f2f8; color: #1a1a2e; font-size: 14px; }

/* ── HEADER ── */
.header { background: linear-gradient(135deg,#1a1a2e 0%,#2c3e6b 100%); color:#fff; padding: 16px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; box-shadow:0 2px 12px rgba(0,0,0,.25); }
.header-left h1 { font-size:1.25rem; font-weight:800; letter-spacing:.5px; }
.header-left .sub { font-size:.78rem; color:#aac4ff; margin-top:2px; }
.header-right { display:flex; gap:8px; align-items:center; }
.btn-sm { background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.3); color:#fff; padding:5px 12px; border-radius:6px; font-size:.78rem; cursor:pointer; transition:.15s; font-weight:600; }
.btn-sm:hover { background:rgba(255,255,255,.25); }

/* ── ALERT BAR ── */
#alert-bar { background:#c0392b; color:#fff; padding:9px 24px; font-size:.84rem; font-weight:700; display:none; align-items:center; gap:8px; flex-wrap:wrap; border-bottom:3px solid #922b21; }

/* ── CONTROLS ── */
.controls { background:#fff; border-bottom:1px solid #dde; padding:12px 24px; display:flex; flex-wrap:wrap; gap:10px; align-items:center; position:sticky; top:0; z-index:100; box-shadow:0 1px 4px rgba(0,0,0,.08); }
.controls input, .controls select { border:1px solid #ccc; border-radius:6px; padding:6px 10px; font-size:.84rem; background:#fff; }
.controls input { width:220px; }
.count-badge { margin-left:auto; font-size:.78rem; color:#666; font-weight:700; background:#f0f2f8; padding:4px 10px; border-radius:12px; }

/* ── GRID ── */
.grid { padding:16px 20px; display:grid; grid-template-columns:repeat(auto-fill, minmax(370px, 1fr)); gap:14px; }

/* ── CARD ── */
.card { background:#fff; border-radius:12px; border:1px solid #e0e4f0; box-shadow:0 1px 4px rgba(0,0,0,.06); overflow:hidden; transition:box-shadow .15s; }
.card:hover { box-shadow:0 4px 20px rgba(0,0,0,.12); }
.card.urgent { border-left:4px solid #c0392b; }
.card.hot    { border-left:4px solid #e67e22; }
.card.warm   { border-left:4px solid #d4ac0d; }
.card.watch  { border-left:4px solid #95a5a6; }
.card.passed { border-left:4px solid #bdc3c7; opacity:.7; }

/* card header */
.card-head { padding:12px 14px 8px; }
.card-top { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:6px; }
.card-name { font-weight:700; font-size:.94rem; line-height:1.3; flex:1; }
.score-pill { font-size:.72rem; font-weight:800; padding:3px 9px; border-radius:20px; color:#fff; white-space:nowrap; }
.s90 { background:#c0392b; }
.s80 { background:#c05621; }
.s70 { background:#b7791f; }
.s60 { background:#4a5568; }
.sw  { background:#95a5a6; }

.card-addr { font-size:.78rem; color:#555; margin-bottom:7px; line-height:1.4; }
.tags { display:flex; flex-wrap:wrap; gap:4px; margin-bottom:8px; }
.tag { font-size:.68rem; font-weight:700; padding:2px 7px; border-radius:10px; text-transform:uppercase; letter-spacing:.3px; }
.tFORECLOSURE { background:#fde8e8; color:#c0392b; }
.tPROBATE     { background:#d6eaf8; color:#1a5276; }
.tTAX\ DEED   { background:#fef9e7; color:#9a7d0a; }
.tNOA         { background:#f0e6fd; color:#6c3483; }
.tMOBILE\ HOME{ background:#d5f5e3; color:#1e8449; }
.tPUBLIC\ SALE{ background:#fde8e8; color:#922b21; }
.tPERMIT      { background:#eaecee; color:#566573; }
.tZONING      { background:#eaecee; color:#566573; }
.tCDD         { background:#eaecee; color:#566573; }
.tWATCH       { background:#eaecee; color:#95a5a6; }
.tMay15 { background:#eaf0ff; color:#1a5276; }
.tMay29 { background:#f5eaff; color:#4a235a; }

.deadline-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:4px; }
.deadline { font-size:.8rem; font-weight:800; }
.deadline.crit    { color:#c0392b; }
.deadline.soon    { color:#e67e22; }
.deadline.future  { color:#1e8449; }
.deadline.passed  { color:#aaa; text-decoration:line-through; }

.atty-info { font-size:.74rem; color:#666; padding:4px 0 6px; border-top:1px solid #f0f0f5; margin-top:4px; line-height:1.5; }

/* ── QUICK LINKS ── */
.quick-links { display:flex; gap:6px; padding:8px 14px; background:#f8f9fd; border-top:1px solid #eef; flex-wrap:wrap; }
.ql-btn { font-size:.72rem; font-weight:700; padding:4px 10px; border-radius:6px; text-decoration:none; display:inline-flex; align-items:center; gap:3px; transition:.1s; border:1px solid transparent; cursor:pointer; }
.ql-tps  { background:#eaf2ff; color:#2471a3; border-color:#aed6f1; }
.ql-pa   { background:#eafaf1; color:#1e8449; border-color:#a9dfbf; }
.ql-pdf  { background:#fef9e7; color:#9a7d0a; border-color:#f9e79f; }
.ql-btn:hover { filter:brightness(.93); }

/* ── PR SECTION ── */
.pr-section { padding:8px 14px 10px; background:#f0f4ff; border-top:1px solid #dde4fa; }
.pr-toggle { font-size:.74rem; font-weight:700; color:#2471a3; cursor:pointer; user-select:none; display:flex; align-items:center; gap:4px; margin-bottom:0; }
.pr-toggle::before { content:'▶'; font-size:.6rem; transition:.15s; }
.pr-toggle.open::before { content:'▼'; }
.pr-fields { display:none; margin-top:8px; display:grid; grid-template-columns:1fr 1fr; gap:5px; }
.pr-fields.visible { display:grid; }
.pr-fields label { font-size:.68rem; color:#555; font-weight:600; text-transform:uppercase; letter-spacing:.3px; }
.pr-fields input, .pr-fields textarea { width:100%; border:1px solid #ccd6f6; border-radius:5px; padding:4px 7px; font-size:.78rem; background:#fff; font-family:inherit; resize:none; }
.pr-fields input:focus, .pr-fields textarea:focus { outline:none; border-color:#2471a3; box-shadow:0 0 0 2px rgba(36,113,163,.15); }
.pr-full { grid-column:1/-1; }
.pr-note { font-size:.68rem; color:#e67e22; font-weight:700; margin-top:4px; grid-column:1/-1; }

/* ── GHL STATUS ── */
.ghl-bar { display:flex; align-items:center; gap:8px; padding:8px 14px; border-top:1px solid #dde4fa; background:#f8fff9; }
.ghl-label { font-size:.72rem; font-weight:700; color:#555; text-transform:uppercase; letter-spacing:.3px; white-space:nowrap; }
.ghl-select { flex:1; border:1px solid #a9dfbf; border-radius:6px; padding:4px 8px; font-size:.78rem; font-weight:600; background:#fff; cursor:pointer; }
.ghl-select.ns  { border-color:#e0e0e0; color:#999; }
.ghl-select.sent { border-color:#aed6f1; color:#2471a3; background:#eaf2ff; }
.ghl-select.pip  { border-color:#a9dfbf; color:#1e8449; background:#eafaf1; }
.ghl-select.cont { border-color:#f9c74f; color:#9a7d0a; background:#fef9e7; }
.ghl-select.closed { border-color:#aaa; color:#444; background:#f0f0f0; }
.ghl-select.dead { border-color:#e0e0e0; color:#bbb; background:#f9f9f9; text-decoration:line-through; }

.pdf-input { flex:1; border:1px solid #f9e79f; border-radius:5px; padding:3px 7px; font-size:.75rem; background:#fff; }

.empty-state { grid-column:1/-1; text-align:center; padding:60px 20px; color:#aaa; }

footer { text-align:center; padding:20px; font-size:.72rem; color:#aaa; }
</style>
